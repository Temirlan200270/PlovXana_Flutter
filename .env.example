# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_PROJECT_REF=your_project_ref

# Dashboard → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Dashboard → Settings → Database → Database password
SUPABASE_DB_PASSWORD=your_db_password

# ─── iiko ────────────────────────────────────────────────────────────────────
# python sync.py orgs  →  покажет список организаций с UUID
IIKO_API_LOGIN=your_iiko_api_login
IIKO_ORGANIZATION_ID=uuid-of-your-iiko-organization
IIKO_TERMINAL_GROUP_ID=   # необязательно

# ─── WhatsApp ────────────────────────────────────────────────────────────────
WHATSAPP_NUMBER=77000000000
