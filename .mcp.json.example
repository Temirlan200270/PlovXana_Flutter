{
  "mcpServers": {
    "dart-flutter": {
      "command": "dart",
      "args": ["mcp-server"]
    },
    "marionette": {
      "command": "dart",
      "args": ["run", "marionette_mcp"]
    },
    "supabase": {
      "command": "npx",
      "args": ["-y", "@supabase/mcp-server-supabase@latest", "--access-token", "YOUR_SUPABASE_PERSONAL_ACCESS_TOKEN"]
    }
  }
}
